# CrisisConnect — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real keys.
# In production (Cloud Run), inject via Secret Manager (see README deploy steps).

# Required — Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for deployment — your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Cloud Run region (e.g. us-central1, asia-south1)
CLOUD_RUN_REGION=us-central1
