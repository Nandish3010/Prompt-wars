# CrisisConnect — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real keys.
# In production (Cloud Run), inject via --set-env-vars or Secret Manager.

# ── Gemini AI (required) ──────────────────────────────────────────────────────
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud (required for deployment) ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
CLOUD_RUN_REGION=asia-south1

# ── Google Maps Geocoding API (server-side, required for precise map pins) ────
# Enable at: console.cloud.google.com → APIs → Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Google Weather API (server-side, required for weather context) ────────────
# Enable at: console.cloud.google.com → APIs → Weather API
GOOGLE_WEATHER_API_KEY=your_google_weather_api_key_here

# ── Google Cloud Speech-to-Text (server-side, required for voice input) ───────
# Enable at: console.cloud.google.com → APIs → Cloud Speech-to-Text API
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key_here

# ── Firebase (client-side, required for Firestore reads + Analytics) ──────────
# Get from: console.firebase.google.com → Project Settings → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:xxx:web:xxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
