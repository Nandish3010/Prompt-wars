{
  "name": "crisisconnect",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":           "next dev",
    "build":         "next build",
    "start":         "next start",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "lint":          "next lint",
    "deploy":        "gcloud run deploy crisisconnect --source . --region asia-south1"
  },
  "dependencies": {
    "next":                   "^14.2.0",
    "react":                  "^18.3.0",
    "react-dom":              "^18.3.0",
    "@google/generative-ai":  "^0.21.0"
  },
  "devDependencies": {
    "typescript":             "^5.4.0",
    "@types/node":            "^20.0.0",
    "@types/react":           "^18.3.0",
    "@types/react-dom":       "^18.3.0",
    "vitest":                 "^1.6.0",
    "@vitest/coverage-v8":    "^1.6.0",
    "jsdom":                  "^24.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0"
  }
}
